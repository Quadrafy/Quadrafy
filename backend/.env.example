PORT=4173
NODE_ENV=development
SESSION_TTL_HOURS=168

# Use um volume persistente e privado. O diretório também guarda auditoria,
# tombstones de recorrências e o histórico retido do chat.
# DATA_DIR=C:/caminho/para/dados

# Os rate limits, o horizonte de 90 dias, o máximo de 8 reservas futuras e a
# retenção de 1.000 mensagens por partida são políticas fixas nesta versão.

# Opcional. Sem a chave, ou se a Anthropic falhar, o teste de nível usa o
# cálculo local determinístico e informa engine.usedFallback=true na resposta.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_TIMEOUT_MS=8000
